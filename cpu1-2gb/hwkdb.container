[Unit]
Description=hwkdb Container
After=network-online.target
Wants=network-online.target

[Container]
ContainerName=hwkdb
AutoUpdate=local
Image=docker.io/hwkcld/hwk-pgsql-17.0:latest
Environment=POSTGRES_PASSWORD=mypassword
Environment=POSTGRES_USER=postgres
Environment=POSTGRES_DB=postgres
Volume=postgres-data:/var/lib/postgresql/data
Volume=/home/postgres/postgresql.conf:/etc/postgresql/postgresql.conf
PublishPort=127.0.0.1:5432:5432
Exec=-c "config_file=/etc/postgresql/postgresql.conf"

[Service]
Restart=always

[Install]
WantedBy=default.target
